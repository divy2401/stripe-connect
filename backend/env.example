# ===============================================
# BACKEND ENVIRONMENT VARIABLES
# ===============================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to git!

# ===============================================
# DATABASE CONFIGURATION
# ===============================================
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database?schema=public
# Example with Docker: postgresql://postgres:postgres@localhost:5432/stripe_connect_demo?schema=public
DATABASE_URL="postgresql://username:password@localhost:5432/stripe_connect_demo?schema=public"

# ===============================================
# STRIPE CONFIGURATION
# ===============================================
# Get these from: https://dashboard.stripe.com/test/apikeys
# Make sure you're in TEST MODE!

# Stripe Secret Key (starts with sk_test_...)
# NEVER share this key or commit it to git!
STRIPE_SECRET_KEY="sk_test_..."

# Stripe Webhook Secret (starts with whsec_...)
# Get this from: stripe listen --forward-to localhost:3001/webhook
# Leave empty initially, fill in after running stripe CLI
STRIPE_WEBHOOK_SECRET=""

# Stripe API Version (automatically set to latest: 2025-09-30.clover)
# This ensures you get the latest features and security updates

# ===============================================
# APPLICATION CONFIGURATION
# ===============================================
# Port for the backend server to run on
PORT=3001

# Environment (development, production, test)
NODE_ENV=development

# ===============================================
# CORS CONFIGURATION
# ===============================================
# Frontend URL for CORS (where your React app runs)
# Default for local development
FRONTEND_URL="http://localhost:5173"

# ===============================================
# NOTES
# ===============================================
# 1. To get Stripe keys:
#    - Go to https://dashboard.stripe.com
#    - Switch to TEST MODE (toggle in top right)
#    - Navigate to Developers → API keys
#    - Copy Secret key (sk_test_...)
#
# 2. To get Webhook secret:
#    - Install Stripe CLI: https://stripe.com/docs/stripe-cli
#    - Run: stripe login
#    - Run: stripe listen --forward-to localhost:3001/webhook
#    - Copy the webhook secret (whsec_...)
#    - Restart backend after adding the secret
#
# 3. Database setup:
#    - Option A: Use Docker: docker-compose up -d
#    - Option B: Install PostgreSQL locally and create database
#
# 4. After setting up .env, run:
#    npm run prisma:generate
#    npm run prisma:migrate
#    npm run dev

