# ===============================================
# FRONTEND ENVIRONMENT VARIABLES
# ===============================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to git!

# ===============================================
# API CONFIGURATION
# ===============================================
# Backend API URL
# Default for local development
VITE_API_BASE_URL=http://localhost:3000

# ===============================================
# STRIPE CONFIGURATION
# ===============================================
# Stripe Publishable Key (starts with pk_test_...)
# Get this from: https://dashboard.stripe.com/test/apikeys
# Make sure you're in TEST MODE!
# This key is safe to expose in frontend (it's public)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ===============================================
# NOTES
# ===============================================
# 1. All frontend environment variables MUST start with VITE_
#    (This is a Vite requirement)
#
# 2. To get Stripe Publishable Key:
#    - Go to https://dashboard.stripe.com
#    - Switch to TEST MODE (toggle in top right)
#    - Navigate to Developers → API keys
#    - Copy Publishable key (pk_test_...)
#    - This key is safe to expose (it's meant to be public)
#
# 3. Backend API URL:
#    - For local development: http://localhost:3001
#    - For production: https://your-backend-domain.com
#    - Make sure backend is running and accessible
#
# 4. After setting up .env, run:
#    npm run dev
#
# 5. Test Cards (Stripe Test Mode):
#    - Success: 4242 4242 4242 4242
#    - Declined: 4000 0000 0000 0002
#    - Insufficient funds: 4000 0000 0000 9995
#    - Use any future expiry date and any 3-digit CVC

